{{#*inline "body"}}
<main class="site-main">

    {{#with post}}
        {{> partials/content width="wide"}}
    {{/with}}

    {{#if @root.custom.show_related_posts}}
        {{> partials/related-posts}}
    {{/if}}

    {{#with post}}
        {{> partials/comments}}
    {{/with}}

</main>
{{/inline}}
{{> default}}