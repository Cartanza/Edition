{{#*inline "body"}}
<main class="site-main">

    {{#with post}}
        {{> partials/content no_image=true}}
    {{/with}}

    {{#is "post"}}
        {{#if @root.custom.show_related_posts}}
            {{> partials/related-posts}}
        {{/if}}

        {{#with post}}
            {{> partials/comments}}
        {{/with}}
    {{/is}}

</main>
{{/inline}}
{{> default}}